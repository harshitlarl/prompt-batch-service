# Copy this file to `.env` (same directory) and fill in the real value. `.env` is read
# automatically by `docker compose` and should NOT be committed (already covered by a typical
# .gitignore `*.env`/`.env` entry - add one if it isn't there yet).
#
# One Postgres instance, mounted by every environment (local, preprod/stage, prod) - this is the
# single connection string all of them use, so `docker compose up` locally sees exactly the same
# batch/prompt state as preprod and prod. Use the DigitalOcean Managed Database's "Connection
# string" (Database -> Connection Details -> Connection string), or your droplet's Postgres
# connection string if you're self-hosting it there instead.
DATABASE_URL=postgresql://doadmin:REPLACE_ME@REPLACE_ME.db.ondigitalocean.com:25060/promptbatch?sslmode=require

# Which config/config-${APP_ENV}.yml to load. Defaults to `local` if unset.
APP_ENV=local
